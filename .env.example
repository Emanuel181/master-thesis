# =============================================================================
# .env.example — VulnIQ (master-thesis)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values for your environment.
# NEVER commit a real `.env` file. `.gitignore` already excludes `.env*`
# (with an explicit exception for `.env.example`).
#
# Quick start (PowerShell):
#   Copy-Item .env.example .env
#   notepad .env
#
# Quick start (bash/zsh):
#   cp .env.example .env
#   $EDITOR .env
#
# After filling values, run:
#   npm install
#   npx prisma generate
#   npx prisma migrate deploy   # or: npx prisma db push  (dev only)
#   npm run dev
#
# Notes:
# - Variables prefixed with NEXT_PUBLIC_ are exposed to the browser. Never put
#   secrets there.
# - Values shown as <...> are placeholders — replace them.
# - Most entries are OPTIONAL in local dev; only the ones marked REQUIRED must
#   be set for the app to boot.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development
# Public base URL of the running app (used by NextAuth, WebAuthn, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Database (REQUIRED) -----------------------------------------------------
# PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
# Optional: max connections in the pg Pool (lib/prisma.js). Default: 10
DATABASE_POOL_MAX=10
# Optional: separate DB/schema used by the read-only demo mode.
DATABASE_URL_DEMO=
DEMO_DB_SCHEMA=demo

# --- NextAuth / Auth.js (REQUIRED) -------------------------------------------
# Generate with: `openssl rand -base64 32`  (or `npx auth secret`)
AUTH_SECRET=
# Legacy aliases — keep in sync with AUTH_SECRET / NEXT_PUBLIC_APP_URL.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- OAuth providers (optional; enable the ones you need) --------------------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

AUTH_GITLAB_ID=
AUTH_GITLAB_SECRET=
# For self-hosted GitLab, override the base URL (default: https://gitlab.com)
GITLAB_BASE_URL=https://gitlab.com

AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# --- Admin / WebAuthn (passkey) ----------------------------------------------
# Comma-separated list of admin emails (checked by /api/auth/admin-check).
ADMIN_EMAILS=
ADMIN_EMAIL=
# WebAuthn Relying Party (must match the visible hostname of NEXT_PUBLIC_APP_URL)
WEBAUTHN_RP_NAME=VulnIQ Admin
WEBAUTHN_RP_ID=localhost
WEBAUTHN_REQUIRE_USER_VERIFICATION=true

# --- Proxy awareness ---------------------------------------------------------
# How the app derives the client IP. One of: aws-alb | cloudflare | nginx | none
PROXY_TYPE=aws-alb

# --- AWS credentials & region ------------------------------------------------
# In production prefer IAM roles over static keys. These are only for local dev.
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- AWS: S3 ------------------------------------------------------------------
# Main S3 bucket used for user project uploads, code snapshots, etc.
AWS_S3_BUCKET_NAME=
# Bucket that stores agent outputs (reviewer/implementer/tester/reporter JSON + PDF)
AGENT_ARTIFACTS_BUCKET=
# Demo-mode bucket/keys (read-only sample data)
DEMO_S3_BUCKET_NAME=
DEMO_AWS_ACCESS_KEY_ID=
DEMO_AWS_SECRET_ACCESS_KEY=

# --- AWS: Step Functions (orchestrator) --------------------------------------
# ARN of the main run-workflow state machine that runs Reviewer → Implementer → Tester → Reporter.
AWS_STEP_FUNCTIONS_ARN=
STEP_FUNCTIONS_ARN=

# --- AWS: Pentest orchestrator (optional) ------------------------------------
PENTEST_STATE_MACHINE_ARN=
PENTEST_CODE_BUCKET=
PENTEST_RESULTS_BUCKET=

# --- AWS: Bedrock Knowledge Base (RAG) ---------------------------------------
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_DATA_SOURCE_ID=

# --- AWS: Orchestrator API (optional direct HTTP path) -----------------------
AWS_ORCHESTRATOR_API_URL=
AWS_ORCHESTRATOR_API_KEY=
# WebSocket endpoint for live agent streaming (browser-visible)
NEXT_PUBLIC_AWS_ORCHESTRATOR_WS_URL=

# --- Webhook / agent HMAC ----------------------------------------------------
# Shared secret used by Lambda agents to sign callback requests to /api/workflow/*.
# Generate with: `openssl rand -hex 32`
WORKFLOW_AGENT_HMAC_SECRET=

# --- Cron / cleanup jobs -----------------------------------------------------
# Protects /api/cron/* endpoints. Generate with: `openssl rand -hex 32`
CRON_SECRET=
CLEANUP_API_SECRET=

# --- Email (SES / SMTP / Brevo) ----------------------------------------------
# Sender address used for system emails (SES).
SES_FROM_EMAIL=no-reply@example.com
EMAIL_FROM=no-reply@example.com
# SMTP fallback (used by NextAuth email provider if enabled).
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
# Brevo (transactional email)
BREVO_API_KEY=

# --- Cloudflare Turnstile (bot protection) -----------------------------------
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=
# Set to `true` to bypass Turnstile in local dev (NEVER in production).
SKIP_TURNSTILE=true

# --- 3rd-party APIs ----------------------------------------------------------
# VirusTotal API key (used by the file-upload virus scanner).
VIRUSTOTAL_API_KEY=

# Google service account (JSON, stringified) for feedback spreadsheet writes.
# Example: '{"type":"service_account","project_id":"...","private_key":"..."}'
GOOGLE_SERVICE_ACCOUNT_KEY=
FEEDBACK_SPREADSHEET_ID=

# --- Legal / compliance ------------------------------------------------------
GDPR_CONTACT_EMAIL=privacy@example.com

