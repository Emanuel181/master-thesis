            "creation_date": "2026-01-10T13:59:29Z",
            "definition": "{\"Comment\":\"Security Assessment Run Workflow\",\"StartAt\":\"InitializeRun\",\"States\":{\"EmitRunFinished\":{\"Next\":\"Success\",\"Parameters\":{\"Entries\":[{\"Detail\":{\"runId.$\":\"$.runId\",\"status\":\"completed\"},\"DetailType\":\"run_finished\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"ResultPath\":null,\"Type\":\"Task\"},\"EmitRunStarted\":{\"Next\":\"ProcessUseCases\",\"Parameters\":{\"Entries\":[{\"Detail\":{\"runId.$\":\"$.runId\",\"totalUseCases.$\":\"$.runContext.useCaseCount\",\"userId.$\":\"$.userId\"},\"DetailType\":\"run_started\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"ResultPath\":null,\"Type\":\"Task\"},\"Fail\":{\"Type\":\"Fail\"},\"HandleError\":{\"Next\":\"Fail\",\"Parameters\":{\"Entries\":[{\"Detail\":{\"error.$\":\"$.error\",\"runId.$\":\"$.runId\"},\"DetailType\":\"run_failed\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"Type\":\"Task\"},\"InitializeRun\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"HandleError\",\"ResultPath\":\"$.error\"}],\"Next\":\"EmitRunStarted\",\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-initialize-run\",\"ResultPath\":\"$.runContext\",\"Type\":\"Task\"},\"ProcessUseCases\":{\"ItemsPath\":\"$.runContext.useCases\",\"Iterator\":{\"StartAt\":\"EmitUseCaseStarted\",\"States\":{\"CheckFixerEnabled\":{\"Choices\":[{\"BooleanEquals\":true,\"Next\":\"ExecuteFixer\",\"Variable\":\"$$.Map.Item.Value.enableFixer\"}],\"Default\":\"CheckImplementerEnabled\",\"Type\":\"Choice\"},\"CheckImplementerEnabled\":{\"Choices\":[{\"BooleanEquals\":true,\"Next\":\"ExecuteImplementer\",\"Variable\":\"$$.Map.Item.Value.enableImplementer\"}],\"Default\":\"ExecuteTester\",\"Type\":\"Choice\"},\"EmitUseCaseFinished\":{\"End\":true,\"Parameters\":{\"Entries\":[{\"Detail\":{\"runId.$\":\"$.runId\",\"status\":\"completed\",\"useCaseId.$\":\"$$.Map.Item.Value.id\"},\"DetailType\":\"usecase_finished\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"ResultPath\":null,\"Type\":\"Task\"},\"EmitUseCaseStarted\":{\"Next\":\"ExecuteReviewer\",\"Parameters\":{\"Entries\":[{\"Detail\":{\"runId.$\":\"$.runId\",\"useCaseId.$\":\"$$.Map.Item.Value.id\",\"useCaseName.$\":\"$$.Map.Item.Value.title\"},\"DetailType\":\"usecase_started\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"ResultPath\":null,\"Type\":\"Task\"},\"ExecuteFixer\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"CheckImplementerEnabled\",\"ResultPath\":\"$.fixerError\"}],\"Next\":\"CheckImplementerEnabled\",\"Parameters\":{\"reviewerOutput.$\":\"$.reviewerOutput\",\"runId.$\":\"$.runId\",\"useCase.$\":\"$$.Map.Item.Value\"},\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-agent-fixer\",\"ResultPath\":\"$.fixerOutput\",\"TimeoutSeconds\":900,\"Type\":\"Task\"},\"ExecuteImplementer\":{\"Next\":\"ExecuteTester\",\"Parameters\":{\"reviewerOutput.$\":\"$.reviewerOutput\",\"runId.$\":\"$.runId\",\"useCase.$\":\"$$.Map.Item.Value\"},\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-agent-implementer\",\"ResultPath\":\"$.implementerOutput\",\"TimeoutSeconds\":900,\"Type\":\"Task\"},\"ExecuteReporter\":{\"Next\":\"EmitUseCaseFinished\",\"Parameters\":{\"implementerOutput.$\":\"$.implementerOutput\",\"reviewerOutput.$\":\"$.reviewerOutput\",\"runId.$\":\"$.runId\",\"testerOutput.$\":\"$.testerOutput\",\"useCase.$\":\"$$.Map.Item.Value\"},\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-agent-reporter\",\"ResultPath\":\"$.reporterOutput\",\"TimeoutSeconds\":600,\"Type\":\"Task\"},\"ExecuteReviewer\":{\"Next\":\"CheckFixerEnabled\",\"Parameters\":{\"knowledgeBaseId.$\":\"$$.Map.Item.Value.knowledgeBaseId\",\"runId.$\":\"$.runId\",\"useCase.$\":\"$$.Map.Item.Value\"},\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-agent-reviewer\",\"ResultPath\":\"$.reviewerOutput\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"States.TaskFailed\"],\"IntervalSeconds\":5,\"MaxAttempts\":2}],\"TimeoutSeconds\":900,\"Type\":\"Task\"},\"ExecuteTester\":{\"Branches\":[{\"StartAt\":\"EC2Pentester\",\"States\":{\"EC2PentestFailed\":{\"End\":true,\"Result\":{\"message\":\"EC2 pentest failed\",\"status\":\"failed\"},\"Type\":\"Pass\"},\"EC2Pentester\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"EC2PentestFailed\",\"ResultPath\":\"$.ec2PentestError\"}],\"End\":true,\"Parameters\":{\"MessageBody\":{\"implementerOutput.$\":\"$.implementerOutput\",\"reviewerOutput.$\":\"$.reviewerOutput\",\"runId.$\":\"$.runId\",\"taskToken.$\":\"$$.Task.Token\",\"useCase.$\":\"$$.Map.Item.Value\"},\"QueueUrl\":\"https://sqs.us-east-1.amazonaws.com/650080740856/dev-pentester-scan-jobs\"},\"Resource\":\"arn:aws:states:::sqs:sendMessage.waitForTaskToken\",\"ResultPath\":\"$.ec2PentestOutput\",\"TimeoutSeconds\":3600,\"Type\":\"Task\"}}},{\"StartAt\":\"CheckPentestEnabled\",\"States\":{\"AutonomousPentestFailed\":{\"End\":true,\"Result\":{\"message\":\"Autonomous pentest failed\",\"status\":\"failed\"},\"Type\":\"Pass\"},\"CheckPentestEnabled\":{\"Choices\":[{\"IsPresent\":true,\"Next\":\"ExecuteAutonomousPentest\",\"Variable\":\"$$.Map.Item.Value.testerModel\"}],\"Default\":\"SkipAutonomousPentest\",\"Type\":\"Choice\"},\"ExecuteAutonomousPentest\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"AutonomousPentestFailed\",\"ResultPath\":\"$.autonomousPentestError\"}],\"End\":true,\"Parameters\":{\"code.$\":\"$$.Map.Item.Value.code\",\"codeType.$\":\"$$.Map.Item.Value.codeType\",\"fixerOutput.$\":\"$.fixerOutput\",\"reviewerOutput.$\":\"$.reviewerOutput\",\"runId.$\":\"$.runId\",\"testerModel.$\":\"$$.Map.Item.Value.testerModel\",\"testerPrompt.$\":\"$$.Map.Item.Value.testerPrompt\",\"useCase.$\":\"$$.Map.Item.Value\",\"userId.$\":\"$.userId\"},\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-agent-tester-pentest\",\"ResultPath\":\"$.autonomousPentestOutput\",\"TimeoutSeconds\":900,\"Type\":\"Task\"},\"SkipAutonomousPentest\":{\"End\":true,\"Result\":{\"message\":\"Autonomous pentest not configured\",\"status\":\"skipped\"},\"Type\":\"Pass\"}}}],\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"ExecuteReporter\",\"ResultPath\":\"$.testerError\"}],\"Next\":\"MergeTesterResults\",\"ResultPath\":\"$.testerOutputs\",\"Type\":\"Parallel\"},\"MergeTesterResults\":{\"Next\":\"ExecuteReporter\",\"Parameters\":{\"autonomousResults.$\":\"$.testerOutputs[1]\",\"combinedStatus\":\"completed\",\"ec2Results.$\":\"$.testerOutputs[0]\"},\"ResultPath\":\"$.testerOutput\",\"Type\":\"Pass\"}}},\"MaxConcurrency\":3,\"Next\":\"EmitRunFinished\",\"ResultPath\":\"$.useCaseResults\",\"Type\":\"Map\"},\"Success\":{\"Type\":\"Succeed\"}}}",
