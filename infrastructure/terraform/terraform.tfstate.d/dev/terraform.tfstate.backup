            "creation_date": "2026-01-10T13:59:29Z",
            "definition": "{\"Comment\":\"Security Assessment Run Workflow\",\"StartAt\":\"InitializeRun\",\"States\":{\"EmitRunFinished\":{\"Next\":\"Success\",\"Parameters\":{\"Entries\":[{\"Detail\":{\"runId.$\":\"$.runId\",\"status\":\"completed\"},\"DetailType\":\"run_finished\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"ResultPath\":null,\"Type\":\"Task\"},\"EmitRunStarted\":{\"Next\":\"ProcessUseCases\",\"Parameters\":{\"Entries\":[{\"Detail\":{\"runId.$\":\"$.runId\",\"totalUseCases.$\":\"$.runContext.useCaseCount\",\"userId.$\":\"$.userId\"},\"DetailType\":\"run_started\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"ResultPath\":null,\"Type\":\"Task\"},\"Fail\":{\"Type\":\"Fail\"},\"HandleError\":{\"Next\":\"Fail\",\"Parameters\":{\"Entries\":[{\"Detail\":{\"error.$\":\"$.error\",\"runId.$\":\"$.runId\"},\"DetailType\":\"run_failed\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"Type\":\"Task\"},\"InitializeRun\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"HandleError\",\"ResultPath\":\"$.error\"}],\"Next\":\"EmitRunStarted\",\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-initialize-run\",\"ResultPath\":\"$.runContext\",\"Type\":\"Task\"},\"ProcessUseCases\":{\"ItemsPath\":\"$.runContext.useCases\",\"Iterator\":{\"StartAt\":\"EmitUseCaseStarted\",\"States\":{\"CheckImplementerEnabled\":{\"Choices\":[{\"BooleanEquals\":true,\"Next\":\"ExecuteImplementer\",\"Variable\":\"$$.Map.Item.Value.enableImplementer\"}],\"Default\":\"CheckTesterEnabled\",\"Type\":\"Choice\"},\"CheckTesterEnabled\":{\"Choices\":[{\"BooleanEquals\":true,\"Next\":\"ExecuteTester\",\"Variable\":\"$$.Map.Item.Value.enableTester\"}],\"Default\":\"ExecuteReporter\",\"Type\":\"Choice\"},\"EmitUseCaseFinished\":{\"End\":true,\"Parameters\":{\"Entries\":[{\"Detail\":{\"runId.$\":\"$.runId\",\"status\":\"completed\",\"useCaseId.$\":\"$$.Map.Item.Value.id\"},\"DetailType\":\"usecase_finished\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"ResultPath\":null,\"Type\":\"Task\"},\"EmitUseCaseStarted\":{\"Next\":\"ExecuteReviewer\",\"Parameters\":{\"Entries\":[{\"Detail\":{\"runId.$\":\"$.runId\",\"useCaseId.$\":\"$$.Map.Item.Value.id\",\"useCaseName.$\":\"$$.Map.Item.Value.title\"},\"DetailType\":\"usecase_started\",\"EventBusName\":\"dev-security-orchestrator\",\"Source\":\"orchestrator\"}]},\"Resource\":\"arn:aws:states:::events:putEvents\",\"ResultPath\":null,\"Type\":\"Task\"},\"ExecuteImplementer\":{\"Next\":\"CheckTesterEnabled\",\"Parameters\":{\"reviewerOutput.$\":\"$.reviewerOutput\",\"runId.$\":\"$.runId\",\"useCase.$\":\"$$.Map.Item.Value\"},\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-agent-implementer\",\"ResultPath\":\"$.implementerOutput\",\"TimeoutSeconds\":900,\"Type\":\"Task\"},\"ExecuteReporter\":{\"Next\":\"EmitUseCaseFinished\",\"Parameters\":{\"implementerOutput.$\":\"$.implementerOutput\",\"reviewerOutput.$\":\"$.reviewerOutput\",\"runId.$\":\"$.runId\",\"testerOutput.$\":\"$.testerOutput\",\"useCase.$\":\"$$.Map.Item.Value\"},\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-agent-reporter\",\"ResultPath\":\"$.reporterOutput\",\"TimeoutSeconds\":600,\"Type\":\"Task\"},\"ExecuteReviewer\":{\"Next\":\"CheckImplementerEnabled\",\"Parameters\":{\"runId.$\":\"$.runId\",\"useCase.$\":\"$$.Map.Item.Value\"},\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-agent-reviewer\",\"ResultPath\":\"$.reviewerOutput\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"States.TaskFailed\"],\"IntervalSeconds\":5,\"MaxAttempts\":2}],\"TimeoutSeconds\":900,\"Type\":\"Task\"},\"ExecuteTester\":{\"Next\":\"ExecuteReporter\",\"Parameters\":{\"implementerOutput.$\":\"$.implementerOutput\",\"runId.$\":\"$.runId\",\"useCase.$\":\"$$.Map.Item.Value\"},\"Resource\":\"arn:aws:lambda:us-east-1:650080740856:function:dev-agent-tester\",\"ResultPath\":\"$.testerOutput\",\"TimeoutSeconds\":1800,\"Type\":\"Task\"}}},\"MaxConcurrency\":3,\"Next\":\"EmitRunFinished\",\"ResultPath\":\"$.useCaseResults\",\"Type\":\"Map\"},\"Success\":{\"Type\":\"Succeed\"}}}",
